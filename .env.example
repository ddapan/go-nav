# 运行模式:
#   未设置或 server -> Node.js 动态模式 (含 /admin 后台与 API 路由)
#   static         -> 纯静态导出 (无 /admin，无 API)
# BUILD_MODE=server

# 后台管理账号（仅在 server 模式下生效）
ADMIN_USER=admin
ADMIN_PASS=admin123

# 登录 session cookie 的 HMAC 密钥，请修改为长随机串
SESSION_SECRET=please-change-me-to-a-long-random-string

# 可选：自定义数据目录（绝对路径）。默认 ./data
# DATA_DIR=/app/data

# Docker Compose 可选：宿主机映射端口，容器内固定为 3000
# PORT=3000

# Docker 镜像仓库名。推送默认使用 doxwant/go-nav；如需自己的命名空间可以在这里覆盖
# IMAGE_NAME=doxwant/go-nav
# 标签默认读取 package.json 的 version
# IMAGE_TAG=1.1.0
# PLATFORMS=linux/amd64,linux/arm64
# PUSH_LATEST=true

# Docker 数据挂载。默认使用命名卷 go-nav-data；如需使用本地目录，取消注释并改路径
# DATA_MOUNT=./data:/app/data
